  <title>Twoje Imię – Portfolio</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- HEADER / O MNIE -->
  <header>
    <h1>Hej, jestem [Twoje Imię]</h1>
    <p>Frontend Developer + Automatyzacja / No-Code</p>
  </header>

  <!-- PROJEKTY -->
  <section id="projekty">
    <h2>Moje projekty</h2>
    <div class="projekt">
      <img src="images/projekt1.png" alt="Projekt 1">
      <h3>Strona wizytówka</h3>
      <p>Stworzyłem prostą stronę dla lokalnego sklepu, zwiększyła sprzedaż o 20%</p>
      <a href="https://linkdoprojektu.com" target="_blank">Zobacz live</a>
      <a href="https://github.com/TWOJ_GITHUB/projekt1" target="_blank">Zobacz kod</a>
    </div>

    <div class="projekt">
      <img src="images/projekt2.png" alt="Projekt 2">
      <h3>Mini sklep online</h3>
      <p>Prosty sklep z React i responsywnym designem</p>
      <a href="https://linkdoprojektu.com" target="_blank">Zobacz live</a>
      <a href="https://github.com/TWOJ_GITHUB/projekt2" target="_blank">Zobacz kod</a>
    </div>

    <!-- Dodaj kolejne projekty w tym samym formacie -->
  </section>

  <!-- KONTAKT -->
  <section id="kontakt">
    <h2>Kontakt</h2>
    <p>Chcesz stronę lub automatyzację? Napisz do mnie!</p>
    <form action="https://formsubmit.co/TWÓJ_EMAIL" method="POST">
      <input type="text" name="name" placeholder="Twoje imię" required>
      <input type="email" name="email" placeholder="Twój e-mail" required>
      <textarea name="message" placeholder="Twoja wiadomość" required></textarea>
      <button type="submit">Wyślij wiadomość</button>
    </form>
  </section>

  <script src="script.js"></script>
</body>
</html>
